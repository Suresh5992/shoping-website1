## Copy to .env and fill values for production use
# Server
PORT=3000

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1234567890

# SendGrid (optional)
SENDGRID_API_KEY=
SENDGRID_FROM=orders@example.com

# SMTP fallback (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
